# =====================================================================
# RTCG Legal AI — environment template
# Kopiraj u .env i popuni stvarne vrijednosti. .env se ne commit-uje.
# =====================================================================

# --- Backend HTTP server ---
PORT=4000
NODE_ENV=development

# --- PostgreSQL (mora se poklapati sa docker-compose.yml) ---
PGHOST=localhost
PGPORT=5432
PGUSER=rtcg
PGPASSWORD=changeme_local_only
PGDATABASE=rtcg_legal_ai

# --- Claude API ---
# claude-sonnet-4-6 je primarni model za RAG i Contract Intelligence.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- LDAP / Active Directory (Faza 2) ---
# Ostavi prazno u Fazi 1 — autentifikacija se uključuje u Fazi 2.
LDAP_URL=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_BASE_DN=

# --- Embedding sidecar (BGE-M3, lokalno) ---
EMBEDDINGS_URL=http://localhost:8001
EMBEDDINGS_PORT=8001

# --- Ingest / OCR ---
# Putanja do Tesseract binarnog fajla (default ako je na PATH-u).
TESSERACT_BIN=tesseract
TESSERACT_LANGS=srp+srp_latn
OCR_DPI=300
UPLOADS_DIR=./data/uploads

# --- Frontend (Vite čita VITE_* varijable) ---
VITE_API_BASE_URL=http://localhost:4000
